# Copy this file to `.env` in the same folder, edit values, then restart `npm start`.

# VendorHub API (must match your running backend)
REACT_APP_API_BASE_URL=http://localhost:5000/api

# Optional: only if notifications hub is not on the same host as API_BASE_URL without /api
# REACT_APP_SIGNALR_ORIGIN=http://localhost:5000
